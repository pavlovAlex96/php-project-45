#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use function cli\line;
use function Hexlet\Code\askAnswer;
use function Hexlet\Code\greetings;
use function Hexlet\Code\setRound;

//  Приветствие
$nameUser = greetings();

//  Получаем колличество раундов
$round = setRound();

//  Правила ответа
line('Answer "yes" if the number is even, otherwise answer "no".');

//  Цикл игры
for ($numdTrueAnswer = 1; $numdTrueAnswer <= $round; $numdTrueAnswer++) {
    //  Генирация выражения
    $task = ['question' => rand(1, 100)];
    $task['answer'] = (($task['question'] % 2) == 0) ? 'yes' : 'no';

    //  Проверка ответа пользователя с решением
    $userAnswer = askAnswer($task ,$nameUser);

    //  Выход из игры при неверном решении
    if ($userAnswer === false) {
        break;
    }

    //  Игра пройдена
    if ($numdTrueAnswer == $round) {
        line('Congratulations, %s!', $nameUser);
    }
}
