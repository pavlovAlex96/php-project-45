#!/usr/bin/env php
<?php

use function cli\line;
use function cli\prompt;
use function Hexlet\Code\greetings;

require __DIR__ . '/../vendor/autoload.php';

//взываем функцию приветствия
greetings();

//правила ответа
line('Answer "yes" if the number is even, otherwise answer "no".');

$i = 0;
do {
    $gen_number = rand(1, 100);
    $correct_answer = (($gen_number % 2) == 0) ? 'yes' : 'no';
    line("Question: %s", $gen_number);
    $usr_answer = prompt('Your answer: ');

    if ($usr_answer === $correct_answer) {
        $i++;
        line('Correct!');
    } else {
        line("'----' is wrong answer ;(. Correct answer was '----'. /n Let's try again, Tirion!");
        break;
    }
} while ($i < 3);
