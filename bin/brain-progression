#!/usr/bin/env php
<?php

use function cli\line;
use function Hexlet\Code\askAnswer;
use function Hexlet\Code\congratulations;
use function Hexlet\Code\Games\getProgression;
use function Hexlet\Code\Games\progressionCreating;
use function Hexlet\Code\greetings;
use function Hexlet\Code\setRound;

require __DIR__ . '/../vendor/autoload.php';

//  Приветствие
$nameUser = greetings();

//  Получаем колличество раундов
$round = setRound();

//  Правила ответа
line('What number is missing in the progression?');

//  Цикл игры
for ($numdTrueAnswer = 1; $numdTrueAnswer <= $round; $numdTrueAnswer++) {
    // Определение стартовых позиций прогресси
    $progressionLength = rand(4, 9);
    $stepPrigression = rand(1, 10);
    $startProgression = rand(1, 100);


    //  Генирация прогрессии
    $progression = progressionCreating($startProgression, $stepPrigression, $progressionLength);

    //  Составление вопроса и ответа
    $task = getProgression($progression, $progressionLength);

    //  Проверка ответа пользователя с решением
    $userAnswer = askAnswer($task, $nameUser);

    // Обнуление прогрессии
    $progression = [];

    //  Выход из игры при неверном решении
    if ($userAnswer === false) {
        break;
    }
    // Поздравление при полном прохождении
    congratulations($numdTrueAnswer, $round, $nameUser);
}
